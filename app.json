{
  "expo": {
    "name": "Muv Car",
    "slug": "muvcar",
    "version": "1.0.0",
    "scheme": "muvar",

    "icon": "./assets/Icon.png",
"splash": {
  "image": "./assets/logo.png",
  "resizeMode": "contain",
  "backgroundColor": "#FFFFFF"
}
,
    "platforms": ["ios", "android"],

    "runtimeVersion": "1.0.0",

    "plugins": [
      "expo-asset",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          }
        }
      ]
    ],

    "android": {
      "package": "com.muvar.app",
      "versionCode": 2,
      "permissions": [
        "POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "VIBRATE"
      ],

      "adaptiveIcon": {
        "foregroundImage": "./assets/IconForeground.png",
        "backgroundColor": "#FFFFFF"
      },

      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDcBy9gu32ST0M7kROJqnXbe0BOC-mJKw4"
        }
      },

       "newArchEnabled": true
    },

    "ios": {
      "bundleIdentifier": "com.muvar.app",
      "supportsTablet": true,
      "newArchEnabled": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },

    "web": {
      "favicon": "./assets/icon.png"
    },

    "extra": {
      "googleWebClientId": "896374568035-p6g77erhvtgnf6e0erh2jf5jos0fbibm.apps.googleusercontent.com",
      "eas": {
        "projectId": "5915e19e-60c2-4bd0-afdc-e383612f8f0d"
      }
    },

    "owner": "carconnect02"
  }
}
